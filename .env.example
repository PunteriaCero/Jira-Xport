# Jira instance URL (no trailing slash)
# Cloud:  https://your-org.atlassian.net
# Server: https://jira.your-company.com
JIRA_URL=https://your-org.atlassian.net

# Account email used to authenticate
JIRA_EMAIL=you@example.com

# API Token (Cloud): https://id.atlassian.com/manage-profile/security/api-tokens
# For Server/DC: use your password instead
JIRA_API_TOKEN=your_api_token_here
